# MagicMirror .gitignore

# =========================================
# SENSITIVE FILES - NEVER COMMIT
# =========================================

# Environment variables (contains secrets)
.env
.env.local
.env.*.local

# User configuration (may contain API keys, passwords)
config/config.js

# API token file (contains bearer token for companion apps)
config/.api_token

# Token storage files (OAuth tokens, session data)
# Plaintext JSON (legacy)
modules/default/**/.*.json
modules/default/**/.*_config.json
# Encrypted token files
modules/default/**/.*.encrypted
modules/default/**/.*_tokens.encrypted
modules/default/**/.*_config.encrypted
.magicmirror/

# SSL/TLS certificates
*.pem
*.key
*.crt
*.p12
certs/

# =========================================
# DEPENDENCIES
# =========================================

node_modules/
package-lock.json

# =========================================
# BUILD & RUNTIME
# =========================================

# Logs
logs/
*.log
npm-debug.log*

# Runtime data
pids/
*.pid
*.lock
.restart_lock
*.seed

# Coverage reports
coverage/
.nyc_output/

# =========================================
# SYSTEM FILES
# =========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# =========================================
# IDE & EDITORS
# =========================================

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
Session.vim
.netrwhist

# =========================================
# TESTING
# =========================================

# Jest
.jest/
jest-results/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# =========================================
# MISCELLANEOUS
# =========================================

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Backup files
*.bak
*.backup
*.old

# Debug files
*.debug

# Custom CSS (user-specific styling)
# Uncomment if you want to track custom.css
# css/custom.css

# =========================================
# DOCUMENTATION (INTERNAL ONLY)
# =========================================
# Keep only README.md and CHANGELOG.md public
# Other docs are for internal development

CLAUDE.md
Collaboration.md
CONTRIBUTING.md
TODO.md
LICENSE.md
docs/
!docs/VOICE_COMMANDS.md
config/newsfeed/README.md
modules/default/*/README.md
modules/default/weather/providers/README.md
modules/default/timer/sounds/README.md

# =========================================
# MOBILE COMPANION APPS (CLOSED SOURCE)
# =========================================
# The mobile apps are not open source and should not be committed
# Only the API documentation and README files are public

# iOS App
mobile/ios/

# Android App
mobile/android/

# Keep only the documentation
!mobile/README.md
!mobile/ios/MagicMirrorRemote/README.md
!mobile/android/README.md

# Worktrees
.worktrees/

# --- Markdown policy --------------------------------------------------------
# Ignore DEVELOPMENT and PROJECT-MANAGEMENT markdown only: plans, specs,
# findings, audits, walkthroughs, progress logs. These stay local and are
# committed only after an explicit document review.
#
# Everything a user needs to run or use the project stays tracked: README,
# usage guides, API/user references, changelogs, licences and trademarks.
#
# IMPORTANT: not all markdown is documentation. The cyber-harness ships
# functional markdown — agents/, skills/, commands/, rules/, contexts/ are
# agent definitions installed into a user's project, and the knowledge_base/
# tree is product content. Never add a blanket *.md rule; it would untrack
# those and silently break the products for anyone cloning.
docs/superpowers/
*_PLAN.md
*_FINDINGS.md
*_AUDIT.md
AUDIT_*.md
walkthrough.md
WALKTHROUGH.md
progress-log.md
PROGRESS.md
STATUS.md
